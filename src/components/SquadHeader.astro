---
interface Props {
  name: string;
  description?: string | null;
  headerImage?: string | null;
}

const { name, description, headerImage } = Astro.props;
---

<div class="mb-6">
  {headerImage && (
    <div
      class="mb-4 w-full overflow-hidden rounded-lg bg-gray-100"
      style="aspect-ratio: 9/4;"
    >
      <img
        src={`/uploads/${headerImage}`}
        alt={`${name} header`}
        class="h-full w-full object-contain"
      />
    </div>
  )}
  <h1 class="text-2xl font-bold text-gray-900">{name}</h1>
  {description && <p class="mt-1 text-gray-600">{description}</p>}
</div>
