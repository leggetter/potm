---
interface Props {
  user: App.Locals["user"];
}

const { user } = Astro.props;
---

<nav class="border-b border-gray-200 bg-white">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3">
    <a href={user ? "/dashboard" : "/"} class="text-lg font-bold text-indigo-600">
      POTM
    </a>
    <div class="flex items-center gap-4">
      <a href="/about" class="text-sm text-gray-600 hover:text-gray-900">About</a>
      {user ? (
        <div class="flex items-center gap-3">
          <a href="/dashboard" class="text-sm text-gray-600 hover:text-gray-900">Dashboard</a>
          <div class="flex items-center gap-2">
            {user.image && (
              <img
                src={user.image}
                alt=""
                class="h-7 w-7 rounded-full"
                referrerpolicy="no-referrer"
              />
            )}
            <span class="text-sm font-medium">{user.name}</span>
          </div>
          <button
            id="sign-out-btn"
            type="button"
            class="cursor-pointer text-sm text-gray-500 hover:text-gray-700"
          >
            Sign out
          </button>
        </div>
      ) : (
        <a
          href="/login"
          class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700"
        >
          Sign in
        </a>
      )}
    </div>
  </div>
</nav>
{user && (
  <script is:inline>
    document.getElementById("sign-out-btn")?.addEventListener("click", async () => {
      window.posthog?.capture("user_signed_out");
      await fetch("/api/auth/sign-out", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: "{}",
      });
      window.posthog?.reset();
      window.location.href = "/";
    });
  </script>
)}
