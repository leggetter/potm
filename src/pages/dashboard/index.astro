---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getUserSquads } from "../../lib/squads";

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const squads = await getUserSquads(Astro.locals.user.id);
const currentUserId = Astro.locals.user.id;
const currentUserEmail = Astro.locals.user.email;
const currentUserName = Astro.locals.user.name;
---

<BaseLayout title="Dashboard">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Your Squads</h1>
    <a
      href="/new"
      class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700"
    >
      New squad
    </a>
  </div>

  {squads.length === 0 ? (
    <div class="mt-8 rounded-lg border-2 border-dashed border-gray-300 p-8 text-center">
      <p class="text-gray-600">You don't have any squads yet.</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/new"
          class="inline-block rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700"
        >
          Create your first squad
        </a>
      </div>
    </div>
  ) : (
    <div class="mt-6 space-y-4">
      {squads.map((squad) => (
        <a
          href={`/${squad.slug}`}
          class="block rounded-lg border border-gray-200 bg-white p-4 shadow-sm hover:border-indigo-300 hover:shadow-md transition-all"
        >
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-gray-900">{squad.name}</h2>
              {squad.description && (
                <p class="mt-1 text-sm text-gray-600">{squad.description}</p>
              )}
            </div>
            <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-600">
              {squad.role}
            </span>
          </div>
        </a>
      ))}
    </div>
  )}
</BaseLayout>

<script is:inline define:vars={{ currentUserId, currentUserEmail, currentUserName }}>
  // Identify the logged-in user with PostHog
  window.posthog?.identify(currentUserId, {
    email: currentUserEmail,
    name: currentUserName,
  });
</script>
