---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { requireSquadAdmin, getSquadBySlug } from "../../lib/squads";
import { db } from "../../db";
import { squads } from "../../db/schema";
import { eq } from "drizzle-orm";
import { validateUpload, saveUpload, deleteUpload } from "../../lib/uploads";

const { squadSlug } = Astro.params;
if (!squadSlug) return Astro.redirect("/dashboard");

const access = await requireSquadAdmin(squadSlug, Astro.locals.user?.id);
if (!access) {
  return new Response("Not found", { status: 404 });
}

const { squad, role } = access;
let error = "";
let success = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString();

  if (action === "update") {
    const name = formData.get("name")?.toString().trim();
    const description = formData.get("description")?.toString().trim() || null;
    const imageFile = formData.get("header_image") as File | null;

    if (!name) {
      error = "Squad name is required.";
    } else {
      let headerImage = squad.headerImage;

      if (imageFile && imageFile.size > 0) {
        const uploadError = validateUpload(imageFile);
        if (uploadError) {
          error = uploadError;
        } else {
          if (squad.headerImage) {
            deleteUpload(squad.headerImage);
          }
          headerImage = await saveUpload(imageFile, `squad-${squad.id}`);
        }
      }

      if (!error) {
        db.update(squads)
          .set({ name, description, headerImage })
          .where(eq(squads.id, squad.id))
          .run();
        success = "Squad updated.";
      }
    }
  } else if (action === "remove_image") {
    if (squad.headerImage) {
      deleteUpload(squad.headerImage);
      db.update(squads)
        .set({ headerImage: null })
        .where(eq(squads.id, squad.id))
        .run();
      success = "Header image removed.";
    }
  } else if (action === "delete_squad" && role === "owner") {
    db.delete(squads).where(eq(squads.id, squad.id)).run();
    if (squad.headerImage) {
      deleteUpload(squad.headerImage);
    }
    return Astro.redirect("/dashboard");
  }
}

// Re-fetch squad after potential updates
const currentSquad = await getSquadBySlug(squadSlug) || squad;
---

<BaseLayout title={`Settings - ${currentSquad.name}`}>
  <div class="mb-4">
    <a href={`/${squad.slug}`} class="text-sm text-indigo-600 hover:text-indigo-700">
      &larr; Back to {currentSquad.name}
    </a>
  </div>

  <h1 class="text-2xl font-bold text-gray-900">Squad Settings</h1>

  {error && (
    <div class="mt-4 rounded-lg bg-red-50 p-3 text-sm text-red-700">{error}</div>
  )}
  {success && (
    <div class="mt-4 rounded-lg bg-green-50 p-3 text-sm text-green-700">{success}</div>
  )}

  <form method="POST" enctype="multipart/form-data" class="mt-6 space-y-4">
    <input type="hidden" name="action" value="update" />

    <div>
      <label for="name" class="block text-sm font-medium text-gray-700">
        Squad name <span class="text-red-500">*</span>
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        value={currentSquad.name}
        class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
      />
    </div>

    <div>
      <label for="description" class="block text-sm font-medium text-gray-700">
        Description
      </label>
      <textarea
        id="description"
        name="description"
        rows="3"
        class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
      >{currentSquad.description}</textarea>
    </div>

    <div>
      <label for="header_image" class="block text-sm font-medium text-gray-700">
        Header image
      </label>
      <p class="mt-1 text-xs text-gray-500">
        Recommended: 1200x400px landscape image (3:1 ratio). JPEG, PNG, or WebP, max 2MB.
      </p>
      {currentSquad.headerImage && (
        <div class="mt-2">
          <img
            src={`/uploads/${currentSquad.headerImage}`}
            alt="Current header"
            class="h-24 w-full rounded-lg object-cover"
          />
          <form method="POST" class="mt-1">
            <input type="hidden" name="action" value="remove_image" />
            <button type="submit" class="text-xs text-red-600 hover:text-red-700">
              Remove image
            </button>
          </form>
        </div>
      )}
      <input
        type="file"
        id="header_image"
        name="header_image"
        accept="image/jpeg,image/png,image/webp"
        class="mt-2 block w-full text-sm text-gray-500 file:mr-4 file:rounded-lg file:border-0 file:bg-indigo-50 file:px-4 file:py-2 file:text-sm file:font-medium file:text-indigo-700 hover:file:bg-indigo-100"
      />
    </div>

    <button
      type="submit"
      class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700"
    >
      Save changes
    </button>
  </form>

  {role === "owner" && (
    <div class="mt-12 border-t border-gray-200 pt-6">
      <h2 class="text-lg font-semibold text-red-600">Danger Zone</h2>
      <p class="mt-1 text-sm text-gray-600">
        Permanently delete this squad, all its players, fixtures, and votes.
      </p>
      <form method="POST" class="mt-4">
        <input type="hidden" name="action" value="delete_squad" />
        <button
          type="submit"
          onclick="return confirm('Are you sure? This cannot be undone.')"
          class="rounded-lg bg-red-600 px-4 py-2 text-sm font-medium text-white hover:bg-red-700"
        >
          Delete squad
        </button>
      </form>
    </div>
  )}
</BaseLayout>
