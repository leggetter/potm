---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { requireSquadAdmin } from "../../../lib/squads";
import { getPublicOrigin } from "../../../lib/public-url";
import { db, sqlite } from "../../../db";
import { squadAdmins, squadInvites } from "../../../db/schema";
import { eq, and, isNull } from "drizzle-orm";
import { randomUUID } from "node:crypto";

const { squadSlug } = Astro.params;
if (!squadSlug) return Astro.redirect("/dashboard");

const access = await requireSquadAdmin(squadSlug, Astro.locals.user?.id);
if (!access) {
  return new Response("Not found", { status: 404 });
}

const { squad, role } = access;
const publicOrigin = getPublicOrigin(Astro.url.origin);
let error = "";
let success = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString();

  if (action === "invite") {
    const email = formData.get("email")?.toString().trim().toLowerCase();
    if (!email) {
      error = "Email is required.";
    } else {
      const token = randomUUID();
      const expiresAt = Date.now() + 7 * 24 * 60 * 60 * 1000; // 7 days

      db.insert(squadInvites)
        .values({
          squadId: squad.id,
          email,
          token,
          invitedBy: Astro.locals.user!.id,
          expiresAt,
        })
        .run();

      success = `Invitation created for ${email}. It appears in Pending Invites below.`;
    }
  } else if (action === "invite_link") {
    const token = randomUUID();
    const expiresAt = Date.now() + 7 * 24 * 60 * 60 * 1000; // 7 days

    db.insert(squadInvites)
      .values({
        squadId: squad.id,
        email: null,
        token,
        invitedBy: Astro.locals.user!.id,
        expiresAt,
      })
      .run();

    success = "Invite link created. It appears in Pending Invites below.";
  } else if (action === "revoke_invite") {
    const inviteId = formData.get("invite_id")?.toString();
    if (inviteId) {
      db.delete(squadInvites)
        .where(
          and(
            eq(squadInvites.id, parseInt(inviteId, 10)),
            eq(squadInvites.squadId, squad.id),
            isNull(squadInvites.acceptedAt)
          )
        )
        .run();
      success = "Invite revoked.";
    }
  } else if (action === "remove_admin" && role === "owner") {
    const userId = formData.get("user_id")?.toString();
    if (userId && userId !== Astro.locals.user!.id) {
      db.delete(squadAdmins)
        .where(
          and(
            eq(squadAdmins.squadId, squad.id),
            eq(squadAdmins.userId, userId)
          )
        )
        .run();
      success = "Admin removed.";
    }
  } else if (action === "leave" && role === "admin") {
    db.delete(squadAdmins)
      .where(
        and(
          eq(squadAdmins.squadId, squad.id),
          eq(squadAdmins.userId, Astro.locals.user!.id)
        )
      )
      .run();
    return Astro.redirect("/dashboard");
  }
}

// Better Auth manages user table — query it via raw SQL
const admins = sqlite
  .prepare(
    `SELECT sa.user_id as userId, sa.role, u.name as userName, u.email as userEmail
     FROM squad_admins sa
     JOIN user u ON sa.user_id = u.id
     WHERE sa.squad_id = ?`
  )
  .all(squad.id) as {
    userId: string;
    role: string;
    userName: string;
    userEmail: string;
  }[];

const pendingInvitesRaw = db
  .select()
  .from(squadInvites)
  .where(
    and(eq(squadInvites.squadId, squad.id), isNull(squadInvites.acceptedAt))
  )
  .all()
  .filter((inv) => inv.expiresAt > Date.now());

// Group by type: email first, then link; build full URL for each
const pendingInvites = pendingInvitesRaw.map((inv) => ({
  ...inv,
  type: inv.email != null ? "email" as const : "link" as const,
  inviteUrl: `${publicOrigin}/${squad.slug}/admins/invite/${inv.token}`,
}));
const pendingEmail = pendingInvites.filter((i) => i.type === "email");
const pendingLink = pendingInvites.filter((i) => i.type === "link");
---

<BaseLayout title={`Admins - ${squad.name}`}>
  <div class="mb-4">
    <a href={`/${squad.slug}`} class="text-sm text-indigo-600 hover:text-indigo-700">
      &larr; Back to {squad.name}
    </a>
  </div>

  <h1 class="text-2xl font-bold text-gray-900">Manage Admins</h1>

  {error && (
    <div class="mt-4 rounded-lg bg-red-50 p-3 text-sm text-red-700">{error}</div>
  )}
  {success && (
    <div class="mt-4 rounded-lg bg-green-50 p-3 text-sm text-green-700">{success}</div>
  )}

  <!-- Current Admins -->
  <section class="mt-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Current Admins</h2>
    <ul class="space-y-2">
      {admins.map((admin) => (
        <li class="flex items-center justify-between rounded-lg border border-gray-200 bg-white px-4 py-3">
          <div>
            <span class="text-sm font-medium text-gray-900">{admin.userName}</span>
            <span class="ml-2 text-xs text-gray-500">{admin.userEmail}</span>
            <span class:list={[
              "ml-2 rounded-full px-2 py-0.5 text-xs font-medium",
              admin.role === "owner"
                ? "bg-indigo-100 text-indigo-700"
                : "bg-gray-100 text-gray-600",
            ]}>
              {admin.role}
            </span>
          </div>
          {role === "owner" && admin.userId !== Astro.locals.user!.id && (
            <form method="POST">
              <input type="hidden" name="action" value="remove_admin" />
              <input type="hidden" name="user_id" value={admin.userId} />
              <button type="submit" class="text-xs text-red-600 hover:text-red-700">
                Remove
              </button>
            </form>
          )}
        </li>
      ))}
    </ul>
  </section>

  <!-- Invite Admin -->
  <section class="mt-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Invite Admin</h2>
    <form method="POST" class="flex gap-2 mb-3">
      <input type="hidden" name="action" value="invite" />
      <input
        type="email"
        name="email"
        placeholder="admin@example.com"
        required
        class="flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
      />
      <button
        type="submit"
        class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700"
      >
        Invite by email
      </button>
    </form>
    <p class="text-sm text-gray-500 mb-3">Or create a one-time link (anyone with the link can accept and become an admin; share only in a trusted channel):</p>
    <form method="POST">
      <input type="hidden" name="action" value="invite_link" />
      <button
        type="submit"
        class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
      >
        Create invite link
      </button>
    </form>
  </section>

  <!-- Pending Invites -->
  {pendingInvites.length > 0 && (
    <section class="mt-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-3">Pending Invites</h2>

      {pendingEmail.length > 0 && (
        <div class="mb-4">
          <h3 class="text-sm font-medium text-gray-700 mb-2">Email invites</h3>
          <ul class="space-y-2">
            {pendingEmail.map((invite) => (
              <li class="flex flex-wrap items-center gap-2 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
                <span class="rounded bg-gray-200 px-2 py-0.5 text-xs font-medium text-gray-700">Email</span>
                <span class="text-sm text-gray-900">{invite.email}</span>
                <span class="text-xs text-gray-500">Expires {new Date(invite.expiresAt).toLocaleDateString()}</span>
                <div class="ml-auto flex items-center gap-2">
                  <div class="flex gap-1">
                    <input
                      type="text"
                      readonly
                      value={invite.inviteUrl}
                      id={`invite-url-${invite.id}`}
                      class="w-64 rounded border border-gray-300 bg-white px-2 py-1 text-xs"
                    />
                    <button
                      type="button"
                      class="copy-invite-btn rounded bg-gray-600 px-2 py-1 text-xs font-medium text-white hover:bg-gray-700"
                      data-invite-id={invite.id}
                    >
                      Copy
                    </button>
                  </div>
                  <form method="POST" class="inline">
                    <input type="hidden" name="action" value="revoke_invite" />
                    <input type="hidden" name="invite_id" value={invite.id} />
                    <button type="submit" class="text-xs text-red-600 hover:text-red-700">Revoke</button>
                  </form>
                </div>
              </li>
            ))}
          </ul>
        </div>
      )}

      {pendingLink.length > 0 && (
        <div>
          <h3 class="text-sm font-medium text-gray-700 mb-2">Link invites (one-time)</h3>
          <ul class="space-y-2">
            {pendingLink.map((invite) => (
              <li class="flex flex-wrap items-center gap-2 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
                <span class="rounded bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-800">Link</span>
                <span class="text-xs text-gray-500">Expires {new Date(invite.expiresAt).toLocaleDateString()}</span>
                <div class="flex-1 min-w-0 flex items-center gap-2">
                  <input
                    type="text"
                    readonly
                    value={invite.inviteUrl}
                    id={`invite-url-${invite.id}`}
                    class="flex-1 min-w-0 rounded border border-gray-300 bg-white px-2 py-1 text-xs"
                  />
                  <button
                    type="button"
                    class="copy-invite-btn shrink-0 rounded bg-blue-600 px-2 py-1 text-xs font-medium text-white hover:bg-blue-700"
                    data-invite-id={invite.id}
                  >
                    Copy
                  </button>
                </div>
                <form method="POST" class="inline">
                  <input type="hidden" name="action" value="revoke_invite" />
                  <input type="hidden" name="invite_id" value={invite.id} />
                  <button type="submit" class="text-xs text-red-600 hover:text-red-700">Revoke</button>
                </form>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>
  )}

  <!-- Leave Squad -->
  {role === "admin" && (
    <div class="mt-12 border-t border-gray-200 pt-6">
      <form method="POST">
        <input type="hidden" name="action" value="leave" />
        <button
          type="submit"
          onclick="return confirm('Are you sure you want to leave this squad?')"
          class="rounded-lg border border-red-300 px-4 py-2 text-sm font-medium text-red-600 hover:bg-red-50"
        >
          Leave squad
        </button>
      </form>
    </div>
  )}
</BaseLayout>

{pendingInvites.length > 0 && (
  <script is:inline>
    document.querySelectorAll(".copy-invite-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-invite-id");
        const input = id ? document.getElementById("invite-url-" + id) : null;
        if (input) {
          input.select();
          navigator.clipboard.writeText(input.value);
          const label = btn.textContent;
          btn.textContent = "Copied!";
          setTimeout(() => { btn.textContent = label; }, 2000);
        }
      });
    });
  </script>
)}
