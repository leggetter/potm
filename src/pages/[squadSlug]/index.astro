---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SquadHeader from "../../components/SquadHeader.astro";
import { requireSquadAdmin } from "../../lib/squads";
import { getSquadFixtures } from "../../lib/fixtures";
import { db } from "../../db";
import { players } from "../../db/schema";
import { eq, and, isNull, isNotNull } from "drizzle-orm";

const { squadSlug } = Astro.params;
if (!squadSlug) return Astro.redirect("/dashboard");

const access = await requireSquadAdmin(squadSlug, Astro.locals.user?.id);
if (!access) {
  return new Response("Not found", { status: 404 });
}

const { squad, role } = access;

let error = "";
let success = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const action = formData.get("action")?.toString();

  if (action === "add_player") {
    const name = formData.get("player_name")?.toString().trim();
    if (!name) {
      error = "Player name is required.";
    } else {
      db.insert(players).values({ squadId: squad.id, name }).run();
      success = `${name} added to the squad.`;
    }
  } else if (action === "archive_player") {
    const playerId = Number(formData.get("player_id"));
    if (playerId) {
      db.update(players)
        .set({ archivedAt: Date.now() })
        .where(eq(players.id, playerId))
        .run();
      success = "Player archived.";
    }
  } else if (action === "unarchive_player") {
    const playerId = Number(formData.get("player_id"));
    if (playerId) {
      db.update(players)
        .set({ archivedAt: null })
        .where(eq(players.id, playerId))
        .run();
      success = "Player restored.";
    }
  } else if (action === "delete_player") {
    const playerId = Number(formData.get("player_id"));
    if (playerId) {
      db.delete(players).where(eq(players.id, playerId)).run();
      success = "Player deleted.";
    }
  }
}

const activePlayers = db
  .select()
  .from(players)
  .where(and(eq(players.squadId, squad.id), isNull(players.archivedAt)))
  .all();

const archivedPlayers = db
  .select()
  .from(players)
  .where(and(eq(players.squadId, squad.id), isNotNull(players.archivedAt)))
  .all();

const fixtureList = await getSquadFixtures(squad.id);
---

<BaseLayout title={squad.name}>
  <SquadHeader
    name={squad.name}
    description={squad.description}
    headerImage={squad.headerImage}
  />

  <div class="flex flex-wrap gap-2 mb-6">
    <a
      href={`/${squad.slug}/fixture/new`}
      class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700"
    >
      New fixture
    </a>
    <a
      href={`/${squad.slug}/settings`}
      class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
    >
      Settings
    </a>
    <a
      href={`/${squad.slug}/admins`}
      class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50"
    >
      Admins
    </a>
  </div>

  {error && (
    <div class="mb-4 rounded-lg bg-red-50 p-3 text-sm text-red-700">{error}</div>
  )}
  {success && (
    <div class="mb-4 rounded-lg bg-green-50 p-3 text-sm text-green-700">{success}</div>
  )}

  <!-- Fixtures Section -->
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Fixtures</h2>

    {fixtureList.length === 0 ? (
      <p class="text-sm text-gray-500">No fixtures yet.</p>
    ) : (
      <div class="space-y-3">
        {fixtureList.map((fixture) => {
          const votingOpen = fixture.votingOpenedAt != null;
          const hasDeadline = fixture.deadline != null;
          const isPast = votingOpen && hasDeadline && fixture.deadline! < Date.now();
          const badge = !votingOpen ? "POTM: Voting not open" : isPast ? "Closed" : "Voting open";
          const badgeClass = !votingOpen
            ? "bg-amber-100 text-amber-800"
            : isPast
              ? "bg-gray-100 text-gray-600"
              : "bg-green-100 text-green-700";
          return (
            <div class="rounded-lg border border-gray-200 bg-white p-4 shadow-sm hover:border-indigo-300 hover:shadow-md transition-all">
              <a href={`/${squad.slug}/fixture/${fixture.slug}`} class="block">
                <div class="flex items-center justify-between">
                  <span class="font-medium text-gray-900">vs {fixture.opponent}</span>
                  <span class:list={["rounded-full px-2 py-0.5 text-xs font-medium", badgeClass]}>
                    {badge}
                  </span>
                </div>
                {votingOpen && hasDeadline && (
                  <p class="mt-1 text-xs text-gray-500">
                    Deadline: {new Date(fixture.deadline!).toLocaleString()}
                  </p>
                )}
              </a>
              <p class="mt-2">
                <a
                  href={`/${squad.slug}/fixture/${fixture.slug}/edit`}
                  class="text-xs text-indigo-600 hover:text-indigo-700"
                >
                  Edit fixture
                </a>
              </p>
            </div>
          );
        })}
      </div>
    )}
  </section>

  <!-- Players Section -->
  <section>
    <h2 class="text-lg font-semibold text-gray-900 mb-3">Players</h2>

    <form method="POST" class="flex gap-2 mb-4">
      <input type="hidden" name="action" value="add_player" />
      <input
        type="text"
        name="player_name"
        placeholder="Player name"
        required
        class="flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
      />
      <button
        type="submit"
        class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700"
      >
        Add
      </button>
    </form>

    {activePlayers.length === 0 ? (
      <p class="text-sm text-gray-500">No players yet. Add some above.</p>
    ) : (
      <ul class="space-y-2">
        {activePlayers.map((player) => (
          <li class="flex items-center justify-between gap-4 rounded-lg border border-gray-200 bg-white px-4 py-2">
            <span class="text-sm font-medium text-gray-900 min-w-0 truncate">{player.name}</span>
            <div class="grid shrink-0 items-center gap-x-1 grid-cols-[2.5rem_3.25rem_2.75rem]">
              <a
                href={`/${squad.slug}/player/${player.id}/edit`}
                class="text-xs text-indigo-600 hover:text-indigo-700"
              >
                Edit
              </a>
              <form method="POST" class="contents">
                <input type="hidden" name="action" value="archive_player" />
                <input type="hidden" name="player_id" value={player.id} />
                <button type="submit" class="text-xs text-gray-500 hover:text-gray-700 text-left">
                  Archive
                </button>
              </form>
              <form method="POST" class="contents">
                <input type="hidden" name="action" value="delete_player" />
                <input type="hidden" name="player_id" value={player.id} />
                <button type="submit" class="text-xs text-red-500 hover:text-red-700 text-left">
                  Delete
                </button>
              </form>
            </div>
          </li>
        ))}
      </ul>
    )}

    {archivedPlayers.length > 0 && (
      <details class="mt-4">
        <summary class="cursor-pointer text-sm text-gray-500 hover:text-gray-700">
          Archived players ({archivedPlayers.length})
        </summary>
        <ul class="mt-2 space-y-2">
          {archivedPlayers.map((player) => (
            <li class="flex items-center justify-between gap-4 rounded-lg border border-gray-200 bg-gray-50 px-4 py-2">
              <span class="text-sm text-gray-500 min-w-0 truncate">{player.name}</span>
              <div class="grid shrink-0 items-center gap-x-1 grid-cols-[2.5rem_3.25rem]">
                <a
                  href={`/${squad.slug}/player/${player.id}/edit`}
                  class="text-xs text-indigo-600 hover:text-indigo-700"
                >
                  Edit
                </a>
                <form method="POST" class="contents">
                  <input type="hidden" name="action" value="unarchive_player" />
                  <input type="hidden" name="player_id" value={player.id} />
                  <button type="submit" class="text-xs text-indigo-600 hover:text-indigo-700 text-left">
                    Restore
                  </button>
                </form>
              </div>
            </li>
          ))}
        </ul>
      </details>
    )}
  </section>
</BaseLayout>
