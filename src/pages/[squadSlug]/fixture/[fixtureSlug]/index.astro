---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import SquadHeader from "../../../../components/SquadHeader.astro";
import ResultsDisplay from "../../../../components/ResultsDisplay.astro";
import { getSquadBySlug, requireSquadAdmin } from "../../../../lib/squads";
import {
  getFixtureBySlug,
  getFixturePlayers,
  getFixtureResults,
} from "../../../../lib/fixtures";
import { renderDescription, descriptionForWhatsApp } from "../../../../lib/description";
import { getPublicOrigin } from "../../../../lib/public-url";
import { db } from "../../../../db";
import { fixtures, votes } from "../../../../db/schema";
import { and, eq } from "drizzle-orm";
import { randomUUID } from "node:crypto";
import { posthog } from "../../../../lib/posthog-server";

const { squadSlug, fixtureSlug } = Astro.params;
if (!squadSlug || !fixtureSlug) {
  return new Response("Not found", { status: 404 });
}

const squad = await getSquadBySlug(squadSlug);
if (!squad) {
  return new Response("Not found", { status: 404 });
}

const fixture = await getFixtureBySlug(squad.id, fixtureSlug);
if (!fixture) {
  return new Response("Not found", { status: 404 });
}

const votingOpen = fixture.votingOpenedAt != null;
const hasDeadline = fixture.deadline != null;
const isPast = votingOpen && hasDeadline && fixture.deadline! < Date.now();
const resultsVisible = fixture.resultsVisibleAt != null;

const access = await requireSquadAdmin(squadSlug, Astro.locals.user?.id);
const isAdmin = !!access;

const votedCookie = Astro.cookies.get(`voted_${fixture.id}`)?.value;
let justVoted = false;
let error = "";

// Read body once; reuse for all POST handling
const formData =
  Astro.request.method === "POST" ? await Astro.request.formData() : null;

// POST: Open voting / Turn off voting (admin only)
if (formData && isAdmin) {
  const action = formData.get("action")?.toString();
  if (action === "close_voting" && votingOpen) {
    db.update(fixtures)
      .set({ votingOpenedAt: null })
      .where(eq(fixtures.id, fixture.id))
      .run();
    posthog.capture({
      distinctId: Astro.locals.user!.id,
      event: "voting_closed",
      properties: {
        squad_slug: squad.slug,
        fixture_slug: fixture.slug,
        opponent: fixture.opponent,
      },
    });
    return Astro.redirect(`/${squad.slug}/fixture/${fixture.slug}`);
  }
  if (action === "open_voting" && !votingOpen) {
    const deadline = formData.get("deadline")?.toString();
    if (!deadline) {
      error = "Voting deadline is required when opening voting.";
    } else {
      const deadlineMs = new Date(deadline).getTime();
      if (deadlineMs <= Date.now()) {
        error = "Deadline must be in the future.";
      } else {
        db.update(fixtures)
          .set({ votingOpenedAt: Date.now(), deadline: deadlineMs })
          .where(eq(fixtures.id, fixture.id))
          .run();
        posthog.capture({
          distinctId: Astro.locals.user!.id,
          event: "voting_opened",
          properties: {
            squad_slug: squad.slug,
            fixture_slug: fixture.slug,
            opponent: fixture.opponent,
            deadline: new Date(deadlineMs).toISOString(),
          },
        });
        return Astro.redirect(`/${squad.slug}/fixture/${fixture.slug}`);
      }
    }
  }
  if (action === "show_results" && !votingOpen && !resultsVisible) {
    db.update(fixtures)
      .set({ resultsVisibleAt: Date.now() })
      .where(eq(fixtures.id, fixture.id))
      .run();
    return Astro.redirect(`/${squad.slug}/fixture/${fixture.slug}`);
  }
}

// POST: Vote submission (when voting open and before deadline; skip if we already set error from open_voting)
if (formData && !error && votingOpen && !isPast && !votedCookie && !justVoted) {
  const voteAction = formData.get("action")?.toString();
  if (voteAction === "vote") {
    const voterName = formData.get("voter_name")?.toString().trim();
    const playerId = Number(formData.get("player_id"));

    if (!voterName) {
      error = "Please enter your name.";
    } else if (!playerId) {
      error = "Please select a player.";
    } else {
      let voterToken = Astro.cookies.get("potm_voter")?.value;
      if (!voterToken) {
        voterToken = randomUUID();
        Astro.cookies.set("potm_voter", voterToken, {
          path: "/",
          maxAge: 365 * 24 * 60 * 60,
          httpOnly: true,
          sameSite: "lax",
        });
      }

      const existing = db
        .select()
        .from(votes)
        .where(
          and(
            eq(votes.fixtureId, fixture.id),
            eq(votes.voterToken, voterToken),
          ),
        )
        .get();

      if (existing) {
        error = "You have already voted for this fixture.";
      } else {
        db.insert(votes)
          .values({
            fixtureId: fixture.id,
            playerId,
            voterName,
            voterToken,
          })
          .run();

        Astro.cookies.set(`voted_${fixture.id}`, "1", {
          path: "/",
          maxAge: 365 * 24 * 60 * 60,
          httpOnly: true,
          sameSite: "lax",
        });

        posthog.capture({
          distinctId: voterToken,
          event: "vote_submitted",
          properties: {
            squad_slug: squad.slug,
            fixture_slug: fixture.slug,
            opponent: fixture.opponent,
            voter_name: voterName,
          },
        });

        justVoted = true;
      }
    }
  }
}

const hasVoted = !!votedCookie || justVoted;

const fixturePlayers =
  votingOpen && !isPast && !hasVoted ? await getFixturePlayers(fixture.id) : [];
const results =
  isPast || resultsVisible || isAdmin
    ? await getFixtureResults(fixture.id)
    : [];
const winners =
  (isPast || resultsVisible) && results.length > 0
    ? results.filter(
        (r) => r.voteCount === results[0].voteCount && r.voteCount > 0,
      )
    : [];

const fixtureUrl = `${getPublicOrigin(Astro.url.origin)}/${squad.slug}/fixture/${fixture.slug}`;
const ogImageUrl = `${fixtureUrl}/og`;

// Default deadline for "Open voting" form: use fixture's existing deadline when reopening, else tomorrow 23:59 (local)
const tomorrow = new Date();
tomorrow.setDate(tomorrow.getDate() + 1);
tomorrow.setHours(23, 59, 0, 0);
const tomorrowStr =
  tomorrow.getFullYear() +
  "-" +
  String(tomorrow.getMonth() + 1).padStart(2, "0") +
  "-" +
  String(tomorrow.getDate()).padStart(2, "0") +
  "T" +
  String(tomorrow.getHours()).padStart(2, "0") +
  ":" +
  String(tomorrow.getMinutes()).padStart(2, "0");
const defaultDeadline =
  fixture.deadline != null
    ? new Date(fixture.deadline - new Date().getTimezoneOffset() * 60000).toISOString().slice(0, 16)
    : tomorrowStr;
const isReopening = !votingOpen && fixture.deadline != null;

// Open voting / Show results only from the day of the fixture onward (calendar day, server local)
const gameDayStart = new Date(fixture.gameDate);
gameDayStart.setHours(0, 0, 0, 0);
const todayStart = new Date();
todayStart.setHours(0, 0, 0, 0);
const isGameDayOrBeyond = gameDayStart.getTime() <= todayStart.getTime();

const totalVotes = results.reduce((sum, r) => sum + r.voteCount, 0);
const hasAtLeastOneVote = totalVotes > 0;
---

<BaseLayout title={`vs ${fixture.opponent} - ${squad.name}`}>
  <Fragment slot="head">
    <meta
      property="og:title"
      content={`${squad.name} vs ${fixture.opponent} — PTOM`}
    />
    <meta
      property="og:description"
      content={votingOpen
        ? "Vote for your Player of the Match"
        : "Fixture details"}
    />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={fixtureUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content={`${squad.name} vs ${fixture.opponent}`}
    />
    <meta name="twitter:image" content={ogImageUrl} />
  </Fragment>
  <SquadHeader
    name={squad.name}
    description={squad.description}
    headerImage={squad.headerImage}
  />

  <div class="mb-5">
    <a
      href={`/${squad.slug}`}
      class="text-sm text-gray-500 hover:text-gray-700 transition-colors"
    >
      &larr; Back to {squad.name}
    </a>
  </div>

  <article
    class="rounded-xl border border-gray-200/80 bg-white shadow-sm mb-6 overflow-hidden"
  >
    <div class="p-5 sm:p-6">
      <!-- Title row: heading + Edit (admin only), so description/URL can be full width below -->
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
        <h1 class="text-2xl font-bold tracking-tight text-gray-900">
          vs {fixture.opponent}
        </h1>
        {
          isAdmin && (
            <a
              href={`/${squad.slug}/fixture/${fixture.slug}/edit`}
              class="shrink-0 inline-flex items-center gap-1.5 rounded-lg bg-indigo-50 px-3 py-2 text-sm font-medium text-indigo-700 hover:bg-indigo-100 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
                <path d="m15 5 4 4"/>
              </svg>
              Edit fixture
            </a>
          )
        }
      </div>
      <div class="min-w-0 w-full mt-4">
        <p class="text-sm text-gray-500">
          {
            new Date(fixture.gameDate).toLocaleDateString("en-GB", {
              weekday: "short",
              day: "numeric",
              month: "short",
              year: "numeric",
            })
          }
          {
            votingOpen && hasDeadline && (
              <>
                <span class="mx-2 text-gray-300">·</span>
                <span class="text-gray-500">
                  Deadline: {new Date(fixture.deadline!).toLocaleString()}
                </span>
                <span
                  class:list={[
                    "ml-2 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium",
                    isPast && resultsVisible
                      ? "bg-amber-100 text-amber-800"
                      : isPast
                        ? "bg-gray-100 text-gray-600"
                        : "bg-emerald-100 text-emerald-700",
                  ]}
                >
                  {isPast && resultsVisible ? "POTM decided" : isPast ? "Closed" : "Voting open"}
                </span>
              </>
            )
          }
          {
            !votingOpen && (
              <span
                class:list={[
                  "ml-2 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium",
                  resultsVisible ? "bg-amber-100 text-amber-800" : hasDeadline && isGameDayOrBeyond ? "bg-gray-100 text-gray-600" : "bg-yellow-100 text-yellow-800",
                ]}
              >
                {resultsVisible ? "POTM decided" : hasDeadline && isGameDayOrBeyond ? "Closed" : "Upcoming"}
              </span>
            )
          }
        </p>
        {
          fixture.description && (
            <div class="mt-3 relative">
              <div
                class="rounded-lg bg-gray-50/80 border border-gray-100 px-3 py-2.5 pr-9 text-sm text-gray-600 description-richtext"
                set:html={renderDescription(fixture.description)}
              />
              <button
                type="button"
                class="copy-whatsapp absolute top-2 right-2 rounded p-1.5 text-gray-400 hover:bg-gray-200/80 hover:text-gray-600 transition-colors"
                title="Copy for WhatsApp"
                data-description={JSON.stringify(descriptionForWhatsApp(fixture.description))}
                data-fixture-url={JSON.stringify(fixtureUrl)}
                aria-label="Copy for WhatsApp"
              >
                <span class="copy-whatsapp-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                    <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
                  </svg>
                </span>
                <span class="copy-whatsapp-done hidden text-xs font-medium text-emerald-600" aria-hidden="true">Copied!</span>
              </button>
            </div>
          )
        }
        {
          isAdmin && (
            <div class="mt-2 flex gap-2 flex-wrap items-center w-full">
              <input
                type="text"
                readonly
                value={fixtureUrl}
                id="fixture-url"
                class="min-w-0 flex-1 rounded border border-gray-200 bg-gray-50 px-2 py-1.5 text-sm text-gray-600"
              />
              <button
                id="copy-fixture-url"
                type="button"
                class="rounded bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700"
              >
                Copy
              </button>
            </div>
          )
        }
      </div>
    </div>
  </article>

  <!-- Admin: Voting closed — show results and/or reopen (only from game day onward) -->
  {
    isAdmin && !votingOpen && !isGameDayOrBeyond && (
      <p class="mb-6 text-sm text-gray-500">
        Open voting and show results are available from the day of the fixture ({new Date(fixture.gameDate).toLocaleDateString("en-GB", { weekday: "short", day: "numeric", month: "short", year: "numeric" })}).
      </p>
    )
  }
  {
    isAdmin && !votingOpen && isGameDayOrBeyond && (
      <div class="mb-6 rounded-xl border border-gray-200 bg-white shadow-sm border-l-4 border-l-amber-500 p-4 sm:p-5">
        <h2 class="text-sm font-semibold text-gray-900 mb-1">
          {isReopening ? "Voting is closed" : "Open voting"}
        </h2>
        <p class="text-sm text-gray-600 mb-4">
          {isReopening
            ? "Show results to everyone, or set a deadline and reopen to accept more votes."
            : "Set a deadline; voting will open until then."}
        </p>
        {
          !resultsVisible && hasAtLeastOneVote && (
            <div class="mb-4 flex flex-col gap-1.5 sm:flex-row sm:items-center sm:gap-2">
              <form method="POST">
                <input type="hidden" name="action" value="show_results" />
                <button
                  type="submit"
                  class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 transition-colors w-full sm:w-auto"
                >
                  Show results
                </button>
              </form>
              <p class="text-xs text-gray-500 sm:mb-0">Make POTM winner and full results visible to everyone.</p>
            </div>
          )
        }
        {!resultsVisible && !hasAtLeastOneVote && (
          <p class="mb-4 text-xs text-gray-500">Show results will be available once at least one vote has been cast.</p>
        )}
        {error && <p class="mb-2 text-sm text-red-600">{error}</p>}
        <form method="POST" class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-end sm:gap-3">
          <input type="hidden" name="action" value="open_voting" />
          <div class="w-full sm:w-auto sm:min-w-[200px]">
            <label
              for="deadline"
              class="block text-xs font-medium text-gray-700"
            >
              Voting deadline
            </label>
            <input
              type="datetime-local"
              id="deadline"
              name="deadline"
              required
              value={defaultDeadline}
              class="mt-1 w-full rounded-lg border border-gray-300 px-2.5 py-1.5 text-sm focus:border-amber-500 focus:ring-1 focus:ring-amber-500"
            />
          </div>
          <button
            type="submit"
            class="rounded-lg bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700 transition-colors w-full sm:w-auto"
          >
            {isReopening ? "Reopen voting" : "Open voting"}
          </button>
        </form>
      </div>
    )
  }

  <!-- Admin: Close voting (when voting is open) -->
  {
    isAdmin && votingOpen && (
      <div class="mb-6 rounded-xl border border-gray-200 bg-white shadow-sm border-l-4 border-l-amber-500 p-4 sm:p-5">
        <form method="POST">
          <input type="hidden" name="action" value="close_voting" />
          <p class="text-sm text-gray-600 mb-3">
            All submissions in? Close voting before the deadline. You can reopen
            if you need to accept more votes.
          </p>
          <button
            type="submit"
            class="rounded-lg border border-amber-600 bg-white px-4 py-2 text-sm font-medium text-amber-700 hover:bg-amber-50 transition-colors"
          >
            Close voting
          </button>
        </form>
      </div>
    )
  }

  <!-- Public / voter content -->
  {
    error && (
      <div class="mb-4 rounded-xl border border-gray-200 bg-white shadow-sm border-l-4 border-l-red-500 p-4 text-sm text-red-700">
        {error}
      </div>
    )
  }

  {
    !votingOpen && !isAdmin && !resultsVisible && (
      <p class="text-gray-500">
        {hasDeadline
          ? "Voting is closed."
          : "POTM voting is not open yet. Check back later."}
      </p>
    )
  }

  {
    (votingOpen && isPast) || resultsVisible ? (
      <section>
        {winners.length === 0 ? (
          <p class="text-gray-500">No votes were cast.</p>
        ) : (
          <div class="rounded-xl border border-gray-200 bg-white shadow-sm border-l-4 border-l-amber-400 p-6 text-center">
            <p class="text-xs font-semibold text-amber-700 uppercase tracking-wider">
              Player of the Match
            </p>
            {winners.map((winner) => (
              <p class="mt-2 text-2xl font-bold text-gray-900">
                {winner.playerName}
              </p>
            ))}
            <span class="mt-3 inline-flex rounded-full bg-amber-100 px-3 py-1 text-sm font-medium text-amber-800">
              POTM Winner{winners.length > 1 ? "s" : ""}
            </span>
          </div>
        )}
        {isAdmin && results.length > 0 && (
          <div class="mt-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-3">
              Full Results
            </h2>
            <ResultsDisplay results={results} showVoters={true} />
          </div>
        )}
      </section>
    ) : votingOpen && hasVoted ? (
      <section>
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm border-l-4 border-l-emerald-500 p-6 text-center">
          <p class="text-lg font-semibold text-emerald-700">
            Thanks for voting!
          </p>
          <p class="mt-2 text-sm text-gray-600">
            {hasDeadline
              ? `Results will be available after ${new Date(fixture.deadline!).toLocaleString()}.`
              : "Results will be available after voting closes."}
          </p>
        </div>
        {isAdmin && results.length > 0 && (
          <div class="mt-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-3">
              Current results (admin only)
            </h2>
            <ResultsDisplay results={results} showVoters={true} />
          </div>
        )}
      </section>
    ) : votingOpen && fixturePlayers.length > 0 ? (
      <section class="space-y-6">
        <form method="POST" class="space-y-5">
          <input type="hidden" name="action" value="vote" />
          <div>
            <label
              for="voter_name"
              class="block text-sm font-medium text-gray-700"
            >
              Your name <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="voter_name"
              name="voter_name"
              required
              class="mt-1 block w-full rounded-xl border border-gray-300 px-3 py-2.5 shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500"
              placeholder="Enter your name"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Who was Player of the Match? <span class="text-red-500">*</span>
            </label>
            <div class="space-y-2">
              {fixturePlayers.map((player) => (
                <label class="flex items-center gap-3 rounded-xl border border-gray-200 bg-white px-4 py-4 cursor-pointer hover:border-indigo-300 hover:bg-indigo-50/30 transition-colors has-checked:border-indigo-500 has-checked:bg-indigo-50/50">
                  <input
                    type="radio"
                    name="player_id"
                    value={player.id}
                    required
                    class="h-5 w-5 border-gray-300 text-indigo-600 focus:ring-indigo-500"
                  />
                  <span class="text-base font-medium text-gray-900">
                    {player.name}
                  </span>
                </label>
              ))}
            </div>
          </div>
          <button
            type="submit"
            class="w-full rounded-xl bg-indigo-600 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 transition-colors"
          >
            Submit vote
          </button>
        </form>
        {isAdmin && results.length > 0 && (
          <div>
            <h2 class="text-lg font-semibold text-gray-900 mb-3">
              Current results (admin only)
            </h2>
            <ResultsDisplay results={results} showVoters={true} />
          </div>
        )}
      </section>
    ) : votingOpen && fixturePlayers.length === 0 ? (
      <p class="text-gray-500">No players in this fixture.</p>
    ) : null
  }
</BaseLayout>

<script is:inline>
  document.getElementById("copy-fixture-url")?.addEventListener("click", () => {
    const input = document.getElementById("fixture-url");
    if (!input) return;
    input.select();
    navigator.clipboard.writeText(input.value);
    const btn = document.getElementById("copy-fixture-url");
    if (btn) btn.textContent = "Copied!";
  });
  document.querySelectorAll(".copy-whatsapp").forEach((btn) => {
    btn.addEventListener("click", () => {
      const rawDesc = btn.getAttribute("data-description");
      const rawUrl = btn.getAttribute("data-fixture-url");
      if (!rawDesc) return;
      try {
        const description = JSON.parse(rawDesc);
        const url = rawUrl ? JSON.parse(rawUrl) : "";
        const text = url ? `${description}\n\n${url}` : description;
        navigator.clipboard.writeText(text);
        const icon = btn.querySelector(".copy-whatsapp-icon");
        const done = btn.querySelector(".copy-whatsapp-done");
        if (icon && done) {
          icon.classList.add("hidden");
          done.classList.remove("hidden");
          btn.setAttribute("title", "Copied!");
          btn.setAttribute("aria-label", "Copied!");
          btn.classList.add("!bg-emerald-100", "!text-emerald-700");
          setTimeout(() => {
            icon.classList.remove("hidden");
            done.classList.add("hidden");
            btn.setAttribute("title", "Copy for WhatsApp");
            btn.setAttribute("aria-label", "Copy for WhatsApp");
            btn.classList.remove("!bg-emerald-100", "!text-emerald-700");
          }, 2000);
        }
      } catch (_) {}
    });
  });
</script>
