---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { requireSquadAdmin } from "../../../lib/squads";
import { generateFixtureSlug } from "../../../lib/fixtures";
import { db } from "../../../db";
import { players, fixtures, fixturePlayers } from "../../../db/schema";
import { eq, and, isNull } from "drizzle-orm";

const { squadSlug } = Astro.params;
if (!squadSlug) return Astro.redirect("/dashboard");

const access = await requireSquadAdmin(squadSlug, Astro.locals.user?.id);
if (!access) {
  return new Response("Not found", { status: 404 });
}

const { squad } = access;
let error = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const opponent = formData.get("opponent")?.toString().trim();
  const deadline = formData.get("deadline")?.toString();
  const selectedPlayers = formData.getAll("players").map(Number);

  if (!opponent) {
    error = "Opponent name is required.";
  } else if (!deadline) {
    error = "Voting deadline is required.";
  } else if (selectedPlayers.length === 0) {
    error = "Select at least one player.";
  } else {
    const deadlineMs = new Date(deadline).getTime();
    if (deadlineMs <= Date.now()) {
      error = "Deadline must be in the future.";
    } else {
      const slug = generateFixtureSlug(opponent);

      const fixture = db
        .insert(fixtures)
        .values({
          squadId: squad.id,
          slug,
          opponent,
          deadline: deadlineMs,
          createdBy: Astro.locals.user!.id,
        })
        .returning({ id: fixtures.id })
        .get();

      for (const playerId of selectedPlayers) {
        db.insert(fixturePlayers)
          .values({ fixtureId: fixture.id, playerId })
          .run();
      }

      return Astro.redirect(`/${squad.slug}/fixture/${slug}`);
    }
  }
}

const activePlayers = db
  .select()
  .from(players)
  .where(and(eq(players.squadId, squad.id), isNull(players.archivedAt)))
  .all();
---

<BaseLayout title={`New Fixture - ${squad.name}`}>
  <div class="mb-4">
    <a href={`/${squad.slug}`} class="text-sm text-indigo-600 hover:text-indigo-700">
      &larr; Back to {squad.name}
    </a>
  </div>

  <h1 class="text-2xl font-bold text-gray-900">Create Fixture</h1>

  {error && (
    <div class="mt-4 rounded-lg bg-red-50 p-3 text-sm text-red-700">{error}</div>
  )}

  {activePlayers.length === 0 ? (
    <div class="mt-6 rounded-lg border-2 border-dashed border-gray-300 p-8 text-center">
      <p class="text-gray-600">Add players to your squad first before creating a fixture.</p>
      <a
        href={`/${squad.slug}`}
        class="mt-4 inline-block rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700"
      >
        Go to squad
      </a>
    </div>
  ) : (
    <form method="POST" class="mt-6 space-y-4">
      <div>
        <label for="opponent" class="block text-sm font-medium text-gray-700">
          Opponent <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="opponent"
          name="opponent"
          required
          class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
          placeholder="e.g. Rovers FC"
        />
      </div>

      <div>
        <label for="deadline" class="block text-sm font-medium text-gray-700">
          Voting deadline <span class="text-red-500">*</span>
        </label>
        <input
          type="datetime-local"
          id="deadline"
          name="deadline"
          required
          class="mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          Players in this fixture <span class="text-red-500">*</span>
        </label>
        <div class="space-y-2">
          {activePlayers.map((player) => (
            <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-white px-4 py-3 cursor-pointer hover:border-indigo-300">
              <input
                type="checkbox"
                name="players"
                value={player.id}
                checked
                class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500"
              />
              <span class="text-sm font-medium text-gray-900">{player.name}</span>
            </label>
          ))}
        </div>
      </div>

      <button
        type="submit"
        class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700"
      >
        Create fixture
      </button>
    </form>
  )}
</BaseLayout>
