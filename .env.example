# Local dev: copy to .env
# Production: copy to .env.production and set BETTER_AUTH_URL to your production URL
# On Fly.io, set these as secrets (see README Deployment section)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:4321

# Optional: PostHog (server-side and client-side). If unset, server-side capture is a no-op.
# POSTHOG_API_KEY=phx_...
# POSTHOG_HOST=https://eu.i.posthog.com
# PUBLIC_POSTHOG_KEY=phc_...
# PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
